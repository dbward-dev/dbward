{
  "family": "dbward-agent",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/dbward-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/dbward-agent-task-role",
  "containerDefinitions": [
    {
      "name": "agent",
      "image": "ghcr.io/dbward-dev/dbward:latest",
      "entryPoint": ["dbward-agent"],
      "command": ["--config", "/config/agent.toml"],
      "secrets": [
        {
          "name": "DBWARD_AGENT_TOKEN",
          "valueFrom": "arn:aws:ssm:ap-northeast-1:ACCOUNT_ID:parameter/dbward/agent-token"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-northeast-1:ACCOUNT_ID:parameter/dbward/database-url"
        }
      ],
      "environment": [
        { "name": "RUST_LOG", "value": "info" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "test -f /tmp/dbward-agent-ready"],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "stopTimeout": 90,
      "readonlyRootFilesystem": true,
      "user": "10001:10001",
      "linuxParameters": {
        "initProcessEnabled": true,
        "capabilities": {
          "drop": ["ALL"]
        },
        "tmpfs": [
          { "containerPath": "/tmp", "size": 64 }
        ]
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dbward-agent",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "agent",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
