{
  "realm": "dbward",
  "enabled": true,
  "clients": [
    {
      "clientId": "dbward-cli",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
      }
    }
  ],
  "groups": [
    {
      "name": "dbward-admins"
    },
    {
      "name": "dbward-developers"
    },
    {
      "name": "dba-team"
    },
    {
      "name": "backend-team"
    }
  ],
  "users": [
    {
      "username": "alice",
      "firstName": "Alice",
      "lastName": "Dev",
      "email": "alice@example.com",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "groups": [
        "dbward-developers",
        "backend-team"
      ]
    },
    {
      "username": "bob",
      "firstName": "Bob",
      "lastName": "Admin",
      "email": "bob@example.com",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "groups": [
        "dbward-admins",
        "backend-team"
      ]
    },
    {
      "username": "carol",
      "firstName": "Carol",
      "lastName": "DBA",
      "email": "carol@example.com",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "carol",
          "temporary": false
        }
      ],
      "groups": [
        "dba-team"
      ]
    }
  ]
}