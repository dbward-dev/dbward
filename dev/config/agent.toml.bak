agent_id = "agent-dev"
poll_interval_ms = 1000
lease_duration_secs = 300
max_concurrent_tasks = 4

[server]
url = "http://dbward-server:3000"
agent_token = "${DBWARD_AGENT_TOKEN}"

[databases.app.development]
url = "postgres://dbward:dbward@postgres:5432/dbward_dev"

[databases.app.production]
url = "postgres://dbward:dbward@postgres:5432/dbward_dev"

[databases.app.staging]
url = "postgres://dbward:dbward@postgres:5432/dbward_dev"

[databases.mysql_dev.development]
url = "mysql://root:dbward@mysql:3306/dbward_test"
