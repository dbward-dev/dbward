{
  "family": "dbward-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/dbward-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/dbward-server-task-role",
  "containerDefinitions": [
    {
      "name": "server",
      "image": "ghcr.io/dbward-dev/dbward:latest",
      "entryPoint": ["dbward-server"],
      "command": ["--data", "/data/dbward.db", "--listen", "0.0.0.0:3000", "--config", "/config/server.toml"],
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "mountPoints": [
        { "sourceVolume": "data", "containerPath": "/data" }
      ],
      "environment": [
        { "name": "RUST_LOG", "value": "info" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:3000/health || exit 1"],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "stopTimeout": 30,
      "readonlyRootFilesystem": true,
      "user": "10001:10001",
      "linuxParameters": {
        "initProcessEnabled": true,
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dbward-server",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "server",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "data",
      "host": { "sourcePath": "/mnt/dbward-data" }
    }
  ]
}
